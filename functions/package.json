{
  "name": "fuelog-functions",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc && cp -r src/templates lib/templates",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.1.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/sharp": "^0.31.1",
    "typescript": "^5.5.4",
    "vitest": "^4.0.18"
  }
}

ALLOWED_EVENT_TYPES=firebase.extensions.firestore-send-email.v1.onStart
AUTH_TYPE=UsernamePassword
DATABASE=(default)
DATABASE_REGION=europe-west2
DEFAULT_FROM=fuel@fuel.paddez.com
DEFAULT_REPLY_TO=fuel@fuel.paddez.com
EVENTARC_CHANNEL=projects/${param:PROJECT_ID}/locations/europe-west4/channels/firebase
firebaseextensions.v1beta.function/ingressSettings=ALLOW_ALL
firebaseextensions.v1beta.function/location=europe-west2
firebaseextensions.v1beta.function/maxInstances=1
firebaseextensions.v1beta.function/minInstances=0
firebaseextensions.v1beta.function/vpcConnectorEgressSettings=VPC_CONNECTOR_EGRESS_SETTINGS_UNSPECIFIED
firebaseextensions.v1beta.v2function/memory=128Mi
MAIL_COLLECTION=mail
OAUTH_PORT=465
OAUTH_SECURE=false
SMTP_CONNECTION_URI=smtps://apikey@smtp.sendgrid.net:465
SMTP_PASSWORD=projects/276662837070/secrets/ext-firestore-send-email-SMTP_PASSWORD/versions/1
TTL_EXPIRE_TYPE=never
TTL_EXPIRE_VALUE=1